{
  "name": "md2pic",
  "version": "0.1.0",
  "private": true,
  "description": "Markdown to social media images — oneimg + doocs/md + Pretext + AI Skills",
  "scripts": {
    "dev": "pnpm --filter @md2pic/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "typescript": "^5.7.2",
    "prettier": "^3.4.2",
    "eslint": "^9.17.0"
  }
}
